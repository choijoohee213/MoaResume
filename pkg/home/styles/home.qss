QPushButton#startButton {
    background-color: #93C5FD;
    color: #1E3A5F;
    border: none;
    border-radius: 16px;
    font-size: 16px;
    font-weight: 700;
    min-width: 200px;
    min-height: 54px;
}

QPushButton#startButton:hover {
    background-color: #60A5FA;
    color: #ffffff;
}

QPushButton#startButton:pressed {
    background-color: #3B82F6;
    color: #ffffff;
}

QLabel#titleLabel {
    font-size: 28px;
    font-weight: 700;
    color: #1E3A5F;
}
